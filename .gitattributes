# Normalize line endings for all text files to LF in the repo,
# but allow Windows checkout to convert to CRLF.
* text=auto eol=lf

# Force LF for Java, JS, CSS, HTML, YAML, properties
*.java   text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.xml    text eol=lf
*.properties text eol=lf

# Binaries - do not modify
*.jar    binary
*.png    binary
*.jpg    binary
*.ico    binary
*.svg    text eol=lf
